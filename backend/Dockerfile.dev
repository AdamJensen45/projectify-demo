FROM maven:3.9.9-eclipse-temurin-17

WORKDIR /app

COPY pom.xml ./
COPY src ./src

# Fail build if sources are missing (helps catch .dockerignore or context issues)
RUN test -f src/main/java/com/projectflow/ProjectFlowApplication.java || \
    (echo "ERROR: Java sources not found - check build context" && exit 1)

RUN mvn -q dependency:go-offline

CMD ["mvn", "spring-boot:run"]
